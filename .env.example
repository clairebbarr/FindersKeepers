# Stage 2 — Supabase (auth, database, storage)
# Create a project at https://supabase.com/dashboard, then Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never prefix with NEXT_PUBLIC_, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Stage 3 — Stripe (subscriptions, checkout) — not wired yet
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (transactional email) — contact autoresponder + admin notifications
# (signup, contact form) are already wired to use this the moment it's set.
# Requires finderskeepersletters.com to be verified as a sending domain in
# the Resend dashboard, or sends will fail.
RESEND_API_KEY=
