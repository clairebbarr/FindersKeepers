# Public Supabase config, committed on purpose so Vercel builds get these
# values from the repo instead of the dashboard. The publishable/anon key and
# project URL are meant to be public (protected by Row Level Security) — this is
# the same value that ships in the browser bundle. Do NOT add the secret key
# (sb_secret_...) or the database URL here; those stay in Vercel only.
NEXT_PUBLIC_SUPABASE_URL=https://srvvllqiinoohyykitki.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_6uB5_9yoZ9UVKZSa1xZcNg_fyE0JLfw
