# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Public Supabase values live here so the deployed build never depends on the
# Vercel dashboard. Safe: publishable/anon key is designed to be public (RLS
# protects data). The SECRET key is NOT in this file — it stays in Vercel only.
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
